---
interface Props {
  headline?: string;
  text?: string;
}

const {
  headline = "Get Monthly Voice Tips — Free",
  text = "Practice routines, vocal science, and teaching insights delivered to your inbox once a month."
} = Astro.props;
---

<aside class="newsletter-cta">
  <div class="newsletter-cta__content">
    <h3 class="newsletter-cta__headline">{headline}</h3>
    <p class="newsletter-cta__text">{text}</p>
    <a href="/newsletter/" class="newsletter-cta__btn">Subscribe Free &rarr;</a>
  </div>
</aside>

<style>
  .newsletter-cta {
    background: var(--color-off-white);
    border: 2px solid var(--color-gold-bright);
    border-radius: 8px;
    padding: 2rem;
    margin: 2rem 0;
    text-align: center;
  }
  .newsletter-cta__headline {
    font-family: var(--font-heading);
    font-size: 1.3rem;
    color: var(--color-navy-deep);
    margin-bottom: 0.5rem;
  }
  .newsletter-cta__text {
    font-family: var(--font-body);
    font-size: 0.92rem;
    color: var(--color-charcoal);
    line-height: 1.6;
    margin-bottom: 1.25rem;
    max-width: 500px;
    margin-left: auto;
    margin-right: auto;
  }
  .newsletter-cta__btn {
    display: inline-block;
    padding: 0.7rem 1.5rem;
    background: var(--color-gold-bright);
    color: var(--color-navy-deep);
    border-radius: 6px;
    font-family: var(--font-body);
    font-weight: 600;
    font-size: 0.92rem;
    text-decoration: none;
    transition: background 0.2s ease, transform 0.1s ease;
  }
  .newsletter-cta__btn:hover {
    background: var(--color-gold-hover);
    transform: translateY(-1px);
  }
</style>
