---
import Layout from '../layouts/BaseLayout.astro';
---

<Layout
  title="Free Monthly Newsletter | Ted's Voice Academy"
  description="Monthly voice tips, practice routines, vocal science, and teaching insights — delivered free from Ted's studio to your inbox."
>
  <main id="main-content">
    <section class="newsletter-hero">
      <div class="container">
        <div class="newsletter-hero__content">
          <p class="newsletter-hero__eyebrow">Free Monthly Newsletter</p>
          <h1 class="newsletter-hero__title">Your Voice, Every Month</h1>
          <p class="newsletter-hero__subtitle">
            Teaching insights, practice routines, and vocal science from four decades in the studio — delivered to your inbox on the first of every month.
          </p>

          <!-- Kit Signup Form -->
          <form id="kit-newsletter-form" class="newsletter-form" novalidate>
            <p class="hidden" aria-hidden="true">
              <label>Don't fill this out: <input name="bot-field" id="nl-bot"></label>
            </p>
            <div class="newsletter-form__row">
              <label for="nl-email" class="sr-only">Email address</label>
              <input
                type="email"
                id="nl-email"
                name="email"
                placeholder="Your email address"
                required
                class="newsletter-form__input"
              >
              <button type="submit" class="newsletter-form__btn" id="nl-submit-btn">
                Subscribe Free
              </button>
            </div>
            <p id="nl-form-message" class="newsletter-form__message" aria-live="polite"></p>
            <p class="newsletter-form__note">No spam. Unsubscribe anytime. Sent once a month.</p>
          </form>
        </div>
      </div>
    </section>

    <!-- What You'll Get -->
    <section class="newsletter-details">
      <div class="container">
        <h2 class="newsletter-details__title">What's Inside Every Issue</h2>
        <div class="newsletter-details__grid">

          <div class="newsletter-card">
            <div class="newsletter-card__icon" aria-hidden="true">&#127908;</div>
            <h3 class="newsletter-card__title">Singing Technique Deep Dives</h3>
            <p class="newsletter-card__text">
              Monthly lessons drawn from The Adaptive Voice Framework™ — the same material Ted uses in private coaching. Five Core Pillars, Eight Adjustable Dials, real exercises you can practice immediately.
            </p>
          </div>

          <div class="newsletter-card">
            <div class="newsletter-card__icon" aria-hidden="true">&#128483;&#65039;</div>
            <h3 class="newsletter-card__title">Speaking & Communication Skills</h3>
            <p class="newsletter-card__text">
              Practical guidance for clear, confident speaking — combining vocal mechanics from AVF with communication patterns from the PASS Profile™ assessment.
            </p>
          </div>

          <div class="newsletter-card">
            <div class="newsletter-card__icon" aria-hidden="true">&#127925;</div>
            <h3 class="newsletter-card__title">Practice Routines & Quick Wins</h3>
            <p class="newsletter-card__text">
              A structured 4-week practice routine each month, plus bite-sized tips you can use in 30 seconds. Real exercises, not vague advice.
            </p>
          </div>

          <div class="newsletter-card">
            <div class="newsletter-card__icon" aria-hidden="true">&#128240;</div>
            <h3 class="newsletter-card__title">Voice News, Trivia & Fun</h3>
            <p class="newsletter-card__text">
              Curated voice science news with Ted's take, vocal health tips, trivia, and the occasional voice joke. Because learning should be enjoyable.
            </p>
          </div>

        </div>
      </div>
    </section>

    <!-- About Ted -->
    <section class="newsletter-about">
      <div class="container">
        <div class="newsletter-about__content">
          <img
            src="/images/ted-headshot.webp"
            alt="Ted Chamberlain"
            class="newsletter-about__photo"
            width="200"
            height="200"
            loading="lazy"
          >
          <div class="newsletter-about__text">
            <h2>From Ted's Studio to Your Inbox</h2>
            <p>
              I'm Ted Chamberlain. I've spent 40 years studying how voices work — teaching singers, coaching speakers, and directing ensembles. I created the Adaptive Voice Framework and the PASS Profile because I believe everyone deserves to understand their own voice.
            </p>
            <p>
              This newsletter is how I share what I'm learning, teaching, and thinking about — one issue per month, no fluff, no sales pitches. Just the good stuff.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Bottom CTA -->
    <section class="newsletter-bottom-cta">
      <div class="container">
        <h2>Ready to understand your voice better?</h2>
        <form id="kit-newsletter-form-bottom" class="newsletter-form newsletter-form--centered" novalidate>
          <p class="hidden" aria-hidden="true">
            <label>Don't fill this out: <input name="bot-field" id="nl-bot-bottom"></label>
          </p>
          <div class="newsletter-form__row">
            <label for="nl-email-bottom" class="sr-only">Email address</label>
            <input
              type="email"
              id="nl-email-bottom"
              name="email"
              placeholder="Your email address"
              required
              class="newsletter-form__input"
            >
            <button type="submit" class="newsletter-form__btn" id="nl-submit-btn-bottom">
              Subscribe Free
            </button>
          </div>
          <p id="nl-form-message-bottom" class="newsletter-form__message" aria-live="polite"></p>
        </form>
      </div>
    </section>
  </main>
</Layout>

<style>
  /* ========== Newsletter Hero ========== */
  .newsletter-hero {
    padding: 5rem 1.5rem 4rem;
    text-align: center;
    background:
      url('/images/noise-texture.png') repeat,
      linear-gradient(180deg, var(--color-navy-deep) 0%, var(--color-navy-medium) 100%);
    background-size: 200px 200px, 100% 100%;
    background-blend-mode: soft-light, normal;
    color: var(--color-cream);
  }
  .newsletter-hero__eyebrow {
    font-family: var(--font-body);
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--color-gold-bright);
    margin-bottom: 1rem;
  }
  .newsletter-hero__title {
    font-family: var(--font-heading);
    font-size: clamp(2rem, 5vw, 3.2rem);
    margin-bottom: 1.25rem;
    line-height: 1.2;
  }
  .newsletter-hero__subtitle {
    font-family: var(--font-body);
    font-size: 1.1rem;
    line-height: 1.7;
    max-width: 600px;
    margin: 0 auto 2.5rem;
    opacity: 0.9;
  }

  /* ========== Newsletter Form ========== */
  .newsletter-form {
    max-width: 480px;
    margin: 0 auto;
  }
  .newsletter-form--centered {
    text-align: center;
  }
  .newsletter-form__row {
    display: flex;
    gap: 0.5rem;
  }
  .newsletter-form__input {
    flex: 1;
    padding: 0.85rem 1rem;
    border: 2px solid rgba(212, 168, 75, 0.3);
    border-radius: 6px;
    background: rgba(255, 255, 255, 0.08);
    color: var(--color-cream);
    font-family: var(--font-body);
    font-size: 1rem;
    transition: border-color 0.2s ease;
  }
  .newsletter-form__input::placeholder {
    color: rgba(245, 240, 225, 0.5);
  }
  .newsletter-form__input:focus {
    outline: none;
    border-color: var(--color-gold-bright);
  }
  .newsletter-form__btn {
    padding: 0.85rem 1.5rem;
    background: var(--color-gold-bright);
    color: var(--color-navy-deep);
    border: none;
    border-radius: 6px;
    font-family: var(--font-body);
    font-weight: 600;
    font-size: 0.95rem;
    cursor: pointer;
    white-space: nowrap;
    transition: background 0.2s ease, transform 0.1s ease;
  }
  .newsletter-form__btn:hover {
    background: var(--color-gold-hover);
    transform: translateY(-1px);
  }
  .newsletter-form__btn:active {
    transform: translateY(0);
  }
  .newsletter-form__message {
    font-size: 0.85rem;
    margin-top: 0.5rem;
    min-height: 1.2em;
  }
  .newsletter-form__note {
    font-size: 0.8rem;
    opacity: 0.6;
    margin-top: 0.75rem;
  }

  /* ========== What You'll Get ========== */
  .newsletter-details {
    padding: 4rem 1.5rem;
    background: var(--color-off-white);
  }
  .newsletter-details__title {
    font-family: var(--font-heading);
    font-size: 1.8rem;
    text-align: center;
    margin-bottom: 2.5rem;
    color: var(--color-navy-deep);
  }
  .newsletter-details__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 1.5rem;
    max-width: 900px;
    margin: 0 auto;
  }
  .newsletter-card {
    background: var(--color-white);
    border-radius: 8px;
    padding: 1.75rem;
    border-top: 3px solid var(--color-gold-bright);
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
  }
  .newsletter-card__icon {
    font-size: 1.8rem;
    margin-bottom: 0.75rem;
  }
  .newsletter-card__title {
    font-family: var(--font-heading);
    font-size: 1.1rem;
    margin-bottom: 0.6rem;
    color: var(--color-navy-deep);
  }
  .newsletter-card__text {
    font-family: var(--font-body);
    font-size: 0.92rem;
    line-height: 1.6;
    color: var(--color-charcoal);
  }

  /* ========== About Ted ========== */
  .newsletter-about {
    padding: 4rem 1.5rem;
    background: var(--color-white);
  }
  .newsletter-about__content {
    display: flex;
    align-items: flex-start;
    gap: 2rem;
    max-width: 750px;
    margin: 0 auto;
  }
  .newsletter-about__photo {
    width: 160px;
    height: 160px;
    border-radius: 50%;
    object-fit: cover;
    border: 3px solid var(--color-gold-bright);
    flex-shrink: 0;
  }
  .newsletter-about__text h2 {
    font-family: var(--font-heading);
    font-size: 1.5rem;
    margin-bottom: 1rem;
    color: var(--color-navy-deep);
  }
  .newsletter-about__text p {
    font-family: var(--font-body);
    font-size: 0.95rem;
    line-height: 1.7;
    color: var(--color-charcoal);
    margin-bottom: 0.75rem;
  }

  /* ========== Bottom CTA ========== */
  .newsletter-bottom-cta {
    padding: 4rem 1.5rem;
    text-align: center;
    background:
      url('/images/noise-texture.png') repeat,
      linear-gradient(180deg, var(--color-navy-medium) 0%, var(--color-navy-deep) 100%);
    background-size: 200px 200px, 100% 100%;
    background-blend-mode: soft-light, normal;
    color: var(--color-cream);
  }
  .newsletter-bottom-cta h2 {
    font-family: var(--font-heading);
    font-size: 1.8rem;
    margin-bottom: 2rem;
  }

  /* ========== Responsive ========== */
  @media (max-width: 600px) {
    .newsletter-form__row {
      flex-direction: column;
    }
    .newsletter-form__btn {
      width: 100%;
    }
    .newsletter-about__content {
      flex-direction: column;
      align-items: center;
      text-align: center;
    }
  }

  .hidden {
    position: absolute;
    overflow: hidden;
    clip: rect(0 0 0 0);
    height: 1px;
    width: 1px;
    margin: -1px;
    padding: 0;
    border: 0;
  }
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
</style>

<script>
  // =============================================
  // KIT NEWSLETTER SIGNUP — LANDING PAGE
  const KIT_FORM_ID = '9235936';
  const KIT_API_KEY = 'hkCV7tQIRqI0-10OR2muAw';
  // =============================================

  function setupKitForm(formId, emailId, botId, msgId, btnId) {
    const form = document.getElementById(formId);
    const msg = document.getElementById(msgId);
    const btn = document.getElementById(btnId);
    const bot = document.getElementById(botId);

    if (!form) return;

    form.addEventListener('submit', async (e) => {
      e.preventDefault();

      if (bot && bot.value) return;

      const emailInput = document.getElementById(emailId);
      const email = emailInput.value.trim();
      if (!email) return;

      if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
        msg.textContent = 'Please enter a valid email address.';
        msg.style.color = '#e74c3c';
        return;
      }

      btn.disabled = true;
      btn.style.opacity = '0.6';
      msg.textContent = '';

      try {
        const response = await fetch(
          `https://api.convertkit.com/v3/forms/${KIT_FORM_ID}/subscribe`,
          {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ api_key: KIT_API_KEY, email })
          }
        );

        if (response.ok) {
          msg.textContent = "You're in! Check your inbox to confirm.";
          msg.style.color = '#d4a84b';
          emailInput.value = '';
        } else {
          msg.textContent = 'Something went wrong. Please try again.';
          msg.style.color = '#e74c3c';
        }
      } catch (err) {
        msg.textContent = 'Connection error. Please try again.';
        msg.style.color = '#e74c3c';
      }

      btn.disabled = false;
      btn.style.opacity = '1';
    });
  }

  // Initialize both forms on this page
  setupKitForm('kit-newsletter-form', 'nl-email', 'nl-bot', 'nl-form-message', 'nl-submit-btn');
  setupKitForm('kit-newsletter-form-bottom', 'nl-email-bottom', 'nl-bot-bottom', 'nl-form-message-bottom', 'nl-submit-btn-bottom');
</script>
